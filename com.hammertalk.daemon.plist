<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hammertalk.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HAMMERTALK_BIN__</string>
    </array>
    <key>RunAtLoad</key>
    <false/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>EnvironmentVariables</key>
    <dict>
        <key>RUST_LOG</key>
        <string>info</string>
    </dict>
    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/hammertalk.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/hammertalk.log</string>
</dict>
</plist>
